# ===== LLM =====
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ===== OpenRouter (Agent2: Perplexity Sonar) =====
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ===== Google Gemini (Agent_Gemini: 対象企業ディープリサーチ) =====
GOOGLE_API_KEY=your_google_api_key_here
# 使用するGeminiモデル（省略時: gemini-2.0-flash）
# 例: GEMINI_MODEL=gemini-2.0-flash
# 例: GEMINI_MODEL=gemini-2.5-flash-preview-05-20
# GEMINI_MODEL=gemini-2.0-flash

# ===== Slack =====
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_APP_TOKEN=xapp-your-app-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here

# ===== Edinet =====
EDINET_API_KEY=your-edinet-api-key-here

# ===== LlamaIndex Embedding (オプション) =====
# OpenAI を使わない場合は HuggingFaceEmbedding を使用（config.py 参照）
OPENAI_API_KEY=your_openai_api_key_here

# ===== CrewAI Enterprise / Tracing 設定 =====
# Batches・Traces ダッシュボードで run 追跡を有効にするには以下を設定する。
# 事前に `crewai login` を実行して認証を済ませておくこと（初回のみ）。
#
# Run 追跡を有効化（Batches が Completed に更新される）
CREWAI_TRACING_ENABLED=true
#
# Enterprise 統合トークン（app.crewai.com > Settings > Account から取得）
# CREWAI_PLATFORM_INTEGRATION_TOKEN=your-enterprise-token-here
#
# ⚠️ 注意: CREWAI_TELEMETRY_OPT_OUT=true または CREWAI_DISABLE_TELEMETRY=true を
# 設定すると、run 追跡イベントも一緒にブロックされ Batches が "Running のまま" になります。
# ローカルデバッグには data/{ticker}/crew_events.jsonl を使用してください。
