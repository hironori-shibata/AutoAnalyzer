# ===== LLM =====
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ===== Slack =====
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_APP_TOKEN=xapp-your-app-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here

# ===== Edinet =====
EDINET_API_KEY=your-edinet-api-key-here

# ===== LlamaIndex Embedding (オプション) =====
# OpenAI を使わない場合は HuggingFaceEmbedding を使用（config.py 参照）
OPENAI_API_KEY=your_openai_api_key_here

# ===== CrewAI テレメトリー設定 =====
# CrewAI Plus の管理画面で "Unknown Crew" / "Running のまま" が発生する場合は
# 以下を true に設定して外部テレメトリーを無効化してください。
# 代替として data/{ticker}/crew_events.jsonl にローカルログが記録されます。
CREWAI_TELEMETRY_OPT_OUT=true
