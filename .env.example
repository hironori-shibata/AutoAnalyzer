# ===== OpenRouter (全LLM共通) =====
OPENROUTER_API_KEY=your_openrouter_api_key_here

# --- モデル設定（省略時はデフォルト値を使用） ---
# フォールバック設定: *_FALLBACKS にカンマ区切りで候補を書くと、レートリミット時に左から順に切り替わる（3つ以上可）
# 例: OPENROUTER_DEFAULT_FALLBACKS=google/gemini-flash-1.5,openai/gpt-4o-mini,anthropic/claude-haiku

# 汎用モデル（Agent1/3a/4/5）
# OPENROUTER_DEFAULT_MODEL=deepseek/deepseek-chat-v3-0324
# OPENROUTER_DEFAULT_FALLBACKS=google/gemini-2.0-flash-001,openai/gpt-4o-mini

# 長文出力モデル（Agent7: 最終レポート）
# OPENROUTER_LONG_MODEL=deepseek/deepseek-chat-v3-0324
# OPENROUTER_LONG_FALLBACKS=google/gemini-2.0-flash-001,openai/gpt-4o-mini

# 推論特化モデル（Agent3/9: 競合・投資家分析）
# OPENROUTER_REASONER_MODEL=deepseek/deepseek-r1
# OPENROUTER_REASONER_FALLBACKS=google/gemini-2.0-flash-thinking-exp,openai/o3-mini

# Web検索内蔵モデル（Agent3: 業界調査）
# OPENROUTER_SEARCH_MODEL=perplexity/sonar
# OPENROUTER_SEARCH_FALLBACKS=perplexity/sonar-pro

# ディープリサーチモデル（Agent2: 対象企業調査）
# OPENROUTER_GEMINI_MODEL=google/gemini-2.0-flash-001
# OPENROUTER_GEMINI_FALLBACKS=google/gemini-2.5-pro-exp-03-25,openai/gpt-4o-mini

# 批評モデル（Agent8: バリュエーション批評）
# OPENROUTER_CRITIC_MODEL=openai/gpt-4o-mini
# OPENROUTER_CRITIC_FALLBACKS=google/gemini-2.0-flash-001,deepseek/deepseek-chat-v3-0324

# ===== Slack =====
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_APP_TOKEN=xapp-your-app-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here

# ===== Edinet =====
EDINET_API_KEY=your-edinet-api-key-here

# ===== デバッグ =====
# DEBUG_MODE=true にすると各エージェントの中間出力をSlackに送信する
# DEBUG_MODE=false

# ===== CrewAI トレーシング =====
# Batches・Tracesダッシュボードでrun追跡を有効にするには以下を設定する
# （事前に `crewai login` で認証が必要）
CREWAI_TRACING_ENABLED=true
# CREWAI_PLATFORM_INTEGRATION_TOKEN=your-enterprise-token-here
